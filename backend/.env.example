# Copy to .env and fill in. The scheme MUST be postgresql+psycopg:// (psycopg v3);
# a bare postgresql:// makes SQLAlchemy look for psycopg2, which isn't installed.

# --- Database (required) ---
# Local Docker Postgres (from docker-compose.yml):
DATABASE_URL=postgresql+psycopg://star:password@localhost:5432/star_crm
#
# Neon (production) — use the POOLED connection string (host has "-pooler"),
# change the scheme to postgresql+psycopg://, and keep ?sslmode=require:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# --- Business-card scanner (required only to use the "Scan card" feature) ---
# Anthropic API key for Claude vision extraction. Get one at console.anthropic.com.
# In production, store this in Secret Manager rather than a plain env var.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the vision model (defaults to a cheap, fast Haiku).
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- CORS (optional) ---
# Comma-separated list of allowed browser origins.
# Local Vite dev server is allowed by default if this is unset.
# FRONTEND_ORIGINS=http://localhost:5173,https://your-frontend.example.com
